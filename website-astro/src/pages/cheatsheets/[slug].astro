---
import Base from "../../layouts/Base.astro";
import CheatsheetView from "../../components/CheatsheetView";
import manifest from "../../content/manifest.json";

export async function getStaticPaths() {
  return manifest.cheatsheets.map((cs) => ({
    params: { slug: cs.slug },
    props:  { meta: cs },
  }));
}

const { meta } = Astro.props;
const data = await import(`../../content/cheatsheets/${meta.slug}.json`);
---

<Base title={`${meta.title} · Cheatsheet`}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
    <!-- Header -->
    <div class="flex items-center gap-2 text-xs text-slate-500 mb-6">
      <a href="/" class="hover:text-slate-300 transition-colors">Home</a>
      <span>›</span>
      <a href="/cheatsheets" class="hover:text-slate-300 transition-colors text-violet-400">Cheatsheets</a>
    </div>

    <div class="rounded-2xl border border-violet-500/30 bg-violet-950/25 p-6 mb-8">
      <div class="flex items-center gap-4">
        <span class="text-4xl">{meta.icon}</span>
        <div>
          <div class="text-xs font-bold uppercase tracking-widest text-violet-400 mb-1">Cheatsheet</div>
          <h1 class="text-2xl font-extrabold text-white">{meta.title}</h1>
        </div>
      </div>
    </div>

    <div class="prose-custom">
      <CheatsheetView client:load content={data.content} />
    </div>

    <div class="mt-10 pt-6 border-t border-slate-800">
      <a href="/cheatsheets" class="text-sm text-slate-400 hover:text-white transition-colors">← All Cheatsheets</a>
    </div>
  </div>
</Base>
