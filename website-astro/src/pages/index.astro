---
import Base from "../layouts/Base.astro";
import { clusterStyle } from "../lib/clusters";
import manifest from "../content/manifest.json";

const { days, clusters } = manifest;

// Group days by cluster
const byCluster = clusters.map((c) => ({
  ...c,
  days: days.filter((d) => d.cluster === c.id),
}));
---

<Base title="Home">
  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 pt-14 pb-10">
    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-2 bg-violet-950/50 border border-violet-700/40 rounded-full px-4 py-1.5 text-xs text-violet-300 mb-5 font-medium">
        <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse"></span>
        ⚡ Premium Edition · 30 Days · C++ DSA
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4">
        <span class="text-white">30 Days to </span>
        <span class="grad-text">DSA in C++</span>
      </h1>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto mb-6">
        Master Data Structures &amp; Algorithms with premium theory, annotated code examples, and interview-level exercises.
      </p>
      <!-- Stats pills -->
      <div class="flex justify-center gap-3 flex-wrap text-xs mb-2">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-violet-950/60 border border-violet-800/40 text-violet-300">📅 30 Days</span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-cyan-950/60 border border-cyan-800/40 text-cyan-300">💻 150 Examples</span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-emerald-950/60 border border-emerald-800/40 text-emerald-300">🏋️ 150 Exercises</span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-amber-950/60 border border-amber-800/40 text-amber-300">✅ 150 Solutions</span>
      </div>
    </div>

    <!-- Cluster legend -->
    <div class="flex flex-wrap justify-center gap-2 mb-12">
      {clusters.map((c) => {
        const s = clusterStyle(c.color);
        return (
          <span class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium border ${s.border} ${s.badge}`}>
            <span>{c.icon}</span>{c.label}
          </span>
        );
      })}
    </div>

    <!-- Day grid per cluster -->
    {byCluster.map((cluster) => {
      const s = clusterStyle(cluster.color);
      return (
        <div class="mb-10">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-lg">{cluster.icon}</span>
            <h2 class={`text-sm font-bold uppercase tracking-widest ${s.text}`}>{cluster.label}</h2>
            <div class={`flex-1 h-px ${s.dot} opacity-20`}></div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3">
            {cluster.days.map((day, i) => {
              const s2 = clusterStyle(day.clusterColor);
              return (
                <a
                  href={`/day/${day.slug}`}
                  class={`group flex items-start gap-3 p-4 rounded-xl border ${s2.border} ${s2.bg} ${s2.glow} transition-all duration-200`}
                  style={`animation-delay: ${i * 40}ms`}
                >
                  <div class={`flex-shrink-0 w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold ${s2.badge}`}>
                    {String(day.day).padStart(2, "0")}
                  </div>
                  <div class="min-w-0">
                    <div class="text-sm font-semibold text-slate-200 group-hover:text-white truncate">{day.title}</div>
                    <div class={`text-xs mt-0.5 ${s2.text}`}>{day.clusterLabel}</div>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      );
    })}

    <!-- Quick links -->
    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 gap-4">
      <a href="/cheatsheets" class="group flex items-center gap-4 p-5 rounded-2xl border border-violet-500/30 bg-violet-950/20 hover:border-violet-400/60 hover:bg-violet-950/40 hover:shadow-[0_0_24px_rgba(124,58,237,.2)] transition-all">
        <span class="text-3xl">📄</span>
        <div>
          <div class="font-bold text-slate-200 group-hover:text-white">Cheatsheets</div>
          <div class="text-xs text-slate-500 mt-0.5">{manifest.cheatsheets.length} quick-reference sheets</div>
        </div>
        <span class="ml-auto text-violet-700 group-hover:text-violet-400 text-lg transition-all group-hover:translate-x-1">→</span>
      </a>
      <div class="flex items-center gap-4 p-5 rounded-2xl border border-amber-800/30 bg-amber-950/10">
        <span class="text-3xl">🏆</span>
        <div>
          <div class="font-bold text-slate-200">Complete Course</div>
          <div class="text-xs text-slate-500 mt-0.5">150 examples · 150 exercises · 150 solutions</div>
        </div>
        <span class="ml-auto text-amber-600 text-xs font-bold px-2 py-0.5 rounded-full bg-amber-900/30 border border-amber-800/30">FULL</span>
      </div>
    </div>
  </section>
</Base>
